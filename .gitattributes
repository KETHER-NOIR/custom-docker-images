# Handle line endings automatically for files detected as text 
# and leave binary files (like images) alone.
* text=auto

# Explicitly declare text files you want to always be LF.
*.js text eol=lf
*.ts text eol=lf
*.py text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.env text eol=lf
*.sh text eol=lf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary